# 05 단계 — 학습용 인프라 .env 예시.
# 실제 .env 는 _커밋 X_ (.gitignore 등록됨). 이 파일을 .env 로 복사해서 시작.

# ---------- Postgres ----------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=learning
POSTGRES_PORT=5432

# ---------- Redis ----------
REDIS_PORT=6379

# ---------- Kafka (Redpanda) ----------
KAFKA_PORT=9092
KAFKA_ADMIN_PORT=9644

# ---------- App (선택, app profile 사용 시) ----------
APP_PORT=8000
