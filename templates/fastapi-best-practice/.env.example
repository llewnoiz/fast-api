# 환경 — dev / staging / prod (logging 형식 / Sentry 활성화 등 결정)
APP_ENV=dev

# DB — 호스트 _개발자_ 기준. 도커 컨테이너 안에선 db:5432 로 override 필요
APP_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/app

# Redis
APP_REDIS_URL=redis://localhost:6379/0

# JWT — 운영은 secrets.token_urlsafe(32) 으로 _반드시 교체_. KMS / Vault 권장.
APP_JWT_SECRET=change-me-in-prod-use-secrets-token-urlsafe-32
APP_JWT_ALGORITHM=HS256
APP_JWT_EXPIRE_MIN=30

# 캐시 TTL (초)
APP_CACHE_TTL_SECONDS=60

# 로그
APP_LOG_LEVEL=INFO
